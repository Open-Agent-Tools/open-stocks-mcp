{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MCP server (HTTP)",
      "type": "python",
      "request": "launch",
      "module": "open_stocks_mcp.server.app",
      "args": [
        "--transport",
        "http",
        "--host",
        "127.0.0.1",
        "--port",
        "3001",
        "--debug"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Pytest: current file",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
